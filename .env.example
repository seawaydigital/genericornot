DATABASE_URL="postgresql://user:password@localhost:5432/genericornot"
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email Magic Link (Resend) — free tier: 3K emails/month
# Sign up at https://resend.com, verify your domain, get API key
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="GenericOrNot <noreply@genericornot.com>"

# Cloudflare R2 (image uploads)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="genericornot-images"
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxx.r2.dev"

# logo.dev API (brand logos) — free tier: 500K req/month
# Sign up at https://logo.dev to get your publishable token
NEXT_PUBLIC_LOGO_DEV_TOKEN=""
